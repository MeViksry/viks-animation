{
  "name": "viks-a",
  "version": "1.0.6",
  "description": "Lightweight JavaScript library for smooth and engaging scroll animations",
  "main": "src/viks.js",
  "style": "dist/viks.min.css",
  "browser": "dist/viks.min.js",
  "scripts": {
    "build:js": "terser src/viks.js --compress --mangle --output dist/viks.min.js --source-map \"url='viks.min.js.map'\"",
    "build:css": "node build-css.js",
    "build": "npm run build:js && npm run build:css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MeViksry/viks-animation.git"
  },
  "keywords": [
    "viks-a",
    "viks-animation"
  ],
  "author": "VIKRI AHPAD TANTOWI",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MeViksry/viks-animation/issues"
  },
  "website": "https://viksanimation.my.id",
  "homepage": "https://github.com/MeViksry/viks-animation",
  "devDependencies": {
    "cssnano": "^7.0.6",
    "postcss": "^8.4.38",
    "terser": "^5.10.0"
  }
}
